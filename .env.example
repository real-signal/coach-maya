# Coach Maya Environment Variables

# Product mode — set to "1" on the public-product deploy to gate landing
# page, force onboarding, and route all Claude calls through /api/anthropic.
# Leave unset on Vasco's personal deploy.
VITE_PRODUCT_MODE=

# AI — browser-side key (Vasco's personal deploy / BYO-key mode).
# In product mode this is ignored; set ANTHROPIC_API_KEY (no VITE_ prefix)
# server-side instead.
VITE_ANTHROPIC_API_KEY=

# AI — server-side key for the public-product deploy. Used by
# /api/anthropic.js so the browser never sees it. Set in Vercel project
# env (NOT here). Leave blank on Vasco's deploy.
ANTHROPIC_API_KEY=

# ElevenLabs voice (optional — falls back to system TTS if absent)
VITE_ELEVENLABS_API_KEY=

# Supabase (optional — app works locally without it)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Push Notifications (optional — VAPID key for web push)
VITE_VAPID_PUBLIC_KEY=
